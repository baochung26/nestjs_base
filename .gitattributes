# Normalize text files in repo to LF for consistent diffs
* text=auto eol=lf

# Keep Windows scripts with CRLF where needed
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
