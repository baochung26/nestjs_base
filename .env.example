# ============================================
# NestJS Application Environment Variables
# ============================================
# Copy this file to .env and update with your actual values
# cp .env.example .env

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
# APP_PORT: Port trên host machine (dùng để truy cập từ browser: http://localhost:APP_PORT)
# - Dùng cho Docker port mapping: ${APP_PORT}:3000
# - Trong Docker: PORT=3000 được set trong docker-compose.yml (container port)
# - Local development: App sẽ đọc APP_PORT hoặc default 3000
APP_PORT=3001

# ============================================
# Database Configuration (Required)
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_db
DB_SSL=false

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT Configuration (Required)
# ============================================
# ⚠️ IMPORTANT: Change this to a strong secret in production (minimum 32 characters)
JWT_SECRET=your-super-secret-key-minimum-32-characters-long-random-string
#
# Access token expiration (short-lived, used for API calls)
# Examples: 15m, 30m, 1h
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
#
# Refresh token expiration (long-lived, used to get new access tokens)
# Examples: 7d, 14d, 30d
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
#
# Backward compatibility (will default to JWT_ACCESS_TOKEN_EXPIRES_IN)
# You can keep this synced with JWT_ACCESS_TOKEN_EXPIRES_IN or leave default
JWT_EXPIRES_IN=15m

# ============================================
# Google OAuth Configuration (Optional)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3001

# ============================================
# Mail Configuration (Optional)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=NestJS App

# ============================================
# Storage Configuration (Optional)
# ============================================
STORAGE_TYPE=local
STORAGE_LOCAL_DESTINATION=./uploads
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# ============================================
# CORS Configuration (Cross-Origin Resource Sharing)
# ============================================
# Comma-separated list of allowed origins for CORS
# Format: http://localhost:3000,http://localhost:3001,https://yourdomain.com
# 
# Examples:
#   Development: http://localhost:3000,http://localhost:3001,http://localhost:3002
#   Production: https://yourdomain.com,https://www.yourdomain.com
#   Multiple: http://localhost:3000,https://staging.yourdomain.com,https://yourdomain.com
#
# ⚠️ IMPORTANT: 
#   - Do NOT use wildcard (*) in production
#   - Use HTTPS in production
#   - Separate multiple origins with commas (no spaces)
#   - Default values: http://localhost:3000,http://localhost:3001,http://localhost:3002
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ============================================
# pgAdmin Configuration (Optional)
# ============================================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ============================================
# Notes
# ============================================
# 1. Required variables: DB_HOST, DB_USER, DB_PASSWORD, DB_NAME, JWT_SECRET
# 2. All other variables have default values and are optional
# 3. For Docker: DB_HOST=postgres, REDIS_HOST=redis (use service names)
# 4. For Local: DB_HOST=localhost, REDIS_HOST=localhost
# 5. See docs/ENV_VALIDATION_GUIDE.md for detailed validation rules
# 6. See docs/CORS_CONFIG_GUIDE.md for CORS configuration details
