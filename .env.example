# ============================================
# NestJS Application Environment Variables
# ============================================
# Copy: cp .env.example .env — rồi sửa giá trị theo môi trường.

# ============================================
# Docker port mapping — chỉ dùng trong docker-compose
# ============================================
# Port trên máy host (bên trái HOST:CONTAINER). Dùng khi truy cập từ browser, redis-cli, pgAdmin.
# Port trong container (5432, 6379, 3000, 80) cố định trong docker-compose.
APP_HOST_PORT=3001
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6380
PGADMIN_HOST_PORT=5050

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
# Port app lắng nghe. Local: đọc từ đây. Docker: PORT=3000 do docker-compose set.
APP_PORT=3000
# Base URL của backend (dùng để build absolute URL như storage file URL)
APP_BASE_URL=http://localhost:3001

# ============================================
# Database Configuration (Required)
# ============================================
# App kết nối DB qua DB_HOST:DB_PORT. Docker: docker-compose set DB_HOST=postgres, DB_PORT=5432 (trong container).
# Chạy app local: đặt DB_HOST=localhost, DB_PORT=POSTGRES_HOST_PORT (5432).
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_db
DB_SSL=false

# ============================================
# Redis Configuration
# ============================================
# App kết nối Redis qua REDIS_HOST:REDIS_PORT. Docker: docker-compose set REDIS_HOST=redis, REDIS_PORT=6379 (trong container).
# Chạy app local: đặt REDIS_HOST=localhost, REDIS_PORT=REDIS_HOST_PORT (6380).
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT Configuration (Required)
# ============================================
# ⚠️ IMPORTANT: Change this to a strong secret in production (minimum 32 characters)
JWT_SECRET=your-super-secret-key-minimum-32-characters-long-random-string
#
# Access token expiration (short-lived, used for API calls)
# Examples: 15m, 30m, 1h
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
#
# Refresh token expiration (long-lived, used to get new access tokens)
# Examples: 7d, 14d, 30d
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
#
# Backward compatibility (will default to JWT_ACCESS_TOKEN_EXPIRES_IN)
# You can keep this synced with JWT_ACCESS_TOKEN_EXPIRES_IN or leave default
JWT_EXPIRES_IN=15m

# ============================================
# Google OAuth Configuration (Optional)
# ============================================
GOOGLE_CLIENT_ID=336599020681-v4jihguob6p36nlkgm7ttj2ulrvvqmar.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000

# ============================================
# Mail Configuration (Optional)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=NestJS App

# ============================================
# Storage Configuration (Optional)
# ============================================
STORAGE_TYPE=local
STORAGE_LOCAL_DESTINATION=./uploads
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# ============================================
# CORS Configuration (Cross-Origin Resource Sharing)
# ============================================
# Comma-separated list of allowed origins for CORS
# Format: http://localhost:3000,http://localhost:3001,https://yourdomain.com
# 
# Examples:
#   Development: http://localhost:3000,http://localhost:3001,http://localhost:3002
#   Production: https://yourdomain.com,https://www.yourdomain.com
#   Multiple: http://localhost:3000,https://staging.yourdomain.com,https://yourdomain.com
#
# ⚠️ IMPORTANT: 
#   - Do NOT use wildcard (*) in production
#   - Use HTTPS in production
#   - Separate multiple origins with commas (no spaces)
#   - Default values: http://localhost:3000,http://localhost:3001,http://localhost:3002
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ============================================
# Bull Board Configuration (Optional - dev only)
# ============================================
# Secret key bảo vệ truy cập Bull Board UI. Để trống = không bảo vệ.
# Truy cập: /admin/queues?key=YOUR_SECRET_KEY
BULL_BOARD_SECRET_KEY=
# BULL_BOARD_PATH=/admin/queues
# BULL_BOARD_ENABLED=true

# ============================================
# pgAdmin Configuration (Optional)
# ============================================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
# Port truy cập pgAdmin trên host: PGADMIN_HOST_PORT (ở section Docker port mapping)

# ============================================
# Notes
# ============================================
# *_HOST_PORT: chỉ dùng trong docker-compose (port trên host). App trong container dùng port cố định (5432, 6379, 3000).
# DB_PORT, REDIS_PORT: port app dùng để kết nối. Chạy local = dùng *_HOST_PORT tương ứng; trong Docker do docker-compose set.
# Required: DB_HOST, DB_USER, DB_PASSWORD, DB_NAME, JWT_SECRET. Xem docs/ENV_VALIDATION_GUIDE.md, docs/CORS_CONFIG_GUIDE.md
