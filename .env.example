# ============================================
# Application
# ============================================
NODE_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3001

# Docker host port mapping (used by docker-compose only)
APP_HOST_PORT=3001
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6380
PGADMIN_HOST_PORT=5050

# ============================================
# Database (required)
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_db
DB_SSL=false

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT (required)
# ============================================
# IMPORTANT: minimum 32 characters in real environments
JWT_SECRET=replace-with-a-strong-secret-minimum-32-characters
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
JWT_EXPIRES_IN=15m

# ============================================
# Google OAuth (optional)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000

# ============================================
# Mail (optional)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-email-password-or-app-password
MAIL_FROM=your-email@example.com
MAIL_FROM_NAME=NestJS App

# ============================================
# Storage (optional)
# ============================================
STORAGE_TYPE=local
STORAGE_LOCAL_DESTINATION=./uploads
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Bull Board (optional, dev)
# ============================================
BULL_BOARD_SECRET_KEY=
# BULL_BOARD_PATH=/admin/queues
# BULL_BOARD_ENABLED=true

# ============================================
# pgAdmin (optional)
# ============================================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ============================================
# Docker watch (optional, dev)
# ============================================
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=1000
WATCHPACK_POLLING=true
TSC_WATCHFILE=UseFsEventsWithFallbackDynamicPolling
